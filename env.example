# ===== REQUIRED =====
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_USER_ID=your_telegram_user_id_here
ADMIN_USERNAME=shreeakash

# ===== DATABASE (persistent file on the VPS disk) =====
# Absolute path recommended on Oracle so systemd always finds it.
DB_PATH=/home/ubuntu/studyguide/studyguide.db

# ===== WEBHOOK (LEAVE EMPTY on Oracle Cloud / VPS) =====
# Only fill these if deploying to Render/Koyeb with a public HTTPS URL.
# On Oracle Cloud keep WEBHOOK_URL empty -> bot runs in POLLING mode automatically.
WEBHOOK_URL=
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook